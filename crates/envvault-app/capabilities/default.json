{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capability for the main window. Permissions are added per feature — never wildcard.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:default"
  ]
}
